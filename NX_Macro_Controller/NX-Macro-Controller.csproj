<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <AssemblyName>NX Macro Controller</AssemblyName>
    <GenerateAssemblyInfo>False</GenerateAssemblyInfo>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>True</UseWindowsForms>
    <TargetFramework>net48</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <CheckForOverflowUnderflow>False</CheckForOverflowUnderflow>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <RootNamespace />
  </PropertyGroup>

  <!-- ===== .NET Framework 組み込み（パス指定不要） ===== -->
  <ItemGroup>
    <Reference Include="System.Management" />
    <Reference Include="PresentationCore" />
    <Reference Include="WindowsBase" />
    <Reference Include="WindowsFormsIntegration" />
    <Reference Include="System.Core" />
    <Reference Include="System.Numerics" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
    <Reference Include="System.Configuration" />
    <Reference Include="System.Xml" />
    <Reference Include="Microsoft.VisualBasic" />
  </ItemGroup>

  <!-- ===== カスタム DLL（lib/ フォルダに配置が必要） ===== -->
  <!-- BZComponent, NxInterface, Suites.Utils は NuGet 非公開のため            -->
  <!-- リポジトリの lib/ フォルダに DLL ファイルを直接コミットしてください      -->
  <ItemGroup>
    <Reference Include="BZComponent">
      <HintPath>lib\BZComponent.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="NxInterface">
      <HintPath>lib\NxInterface.dll</HintPath>
      <Private>True</Private>
    </Reference>
    <Reference Include="Suites.Utils">
      <HintPath>lib\Suites.Utils.dll</HintPath>
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <!-- ===== NuGet パッケージ（自動復元） ===== -->
  <ItemGroup>
    <!-- UI / コードエディタ -->
    <PackageReference Include="ICSharpCode.AvalonEdit" Version="6.3.0.90" />

    <!-- ゲームパッド入力 -->
    <PackageReference Include="Vortice.XInput" Version="3.5.0" />
    <PackageReference Include="SharpDX.DirectInput" Version="4.2.0" />

    <!-- 映像キャプチャ -->
    <PackageReference Include="DirectShowLib-2005" Version="1.0.0" />

    <!-- 画像処理 -->
    <PackageReference Include="OpenCvSharp4.Windows" Version="4.10.0.20241024" />
    <PackageReference Include="OpenCvSharp4.Extensions" Version="4.10.0.20241024" />

    <!-- C# / Python スクリプト実行 -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Scripting" Version="4.9.2" />
    <PackageReference Include="IronPython" Version="3.4.1" />

    <!-- Discord RPC -->
    <PackageReference Include="DiscordRichPresence" Version="1.2.1.24" />

    <!-- シリアル通信 -->
    <PackageReference Include="RJCP.SerialPortStream" Version="2.4.1" />

    <!-- ユーティリティ -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="PSTaskDialog" Version="0.0.4" />
    <PackageReference Include="UrlBase64" Version="0.1.2" />
  </ItemGroup>

</Project>
